<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
		xmlns="http://jasperreports.sourceforge.net/jasperreports"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="
        http://jasperreports.sourceforge.net/jasperreports
        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"

		name="booking_report"
		pageWidth="595"
		pageHeight="842"
		columnWidth="555"
		leftMargin="20"
		rightMargin="20"
		topMargin="20"
		bottomMargin="20"
		uuid="123e4567-e89b-12d3-a456-426614174000">

	<!-- ================= FIELDS ================= -->

	<field name="id" class="java.lang.Long"/>
	<field name="customerName" class="java.lang.String"/>
	<field name="customerEmail" class="java.lang.String"/>
	<field name="bookingStatus" class="java.lang.String"/>
	<field name="salonName" class="java.lang.String"/>
	<field name="salonAddress" class="java.lang.String"/>
	<field name="salonPhone" class="java.lang.String"/>
	<field name="salonEmail" class="java.lang.String"/>
	<field name="totalPrice" class="java.lang.Integer"/>

	<!-- ================= TITLE ================= -->

	<title>
		<band height="80">

			<staticText>
				<reportElement x="0" y="10" width="555" height="30"/>
				<textElement textAlignment="Center">
					<font size="20" isBold="true"/>
				</textElement>
				<text><![CDATA[BOOKING CONFIRMATION]]></text>
			</staticText>

			<textField>
				<reportElement x="0" y="50" width="555" height="20"/>
				<textElement textAlignment="Center"/>
				<textFieldExpression><![CDATA[
                    "Booking ID : " + $F{id}
                ]]></textFieldExpression>
			</textField>

		</band>
	</title>

	<!-- ================= HEADER ================= -->

	<pageHeader>
		<band height="120">

			<staticText>
				<reportElement x="0" y="0" width="200" height="25"/>
				<textElement>
					<font size="16" isBold="true"/>
				</textElement>
				<text><![CDATA[Customer Details]]></text>
			</staticText>

			<staticText>
				<reportElement x="0" y="35" width="120" height="20"/>
				<text><![CDATA[Name :]]></text>
			</staticText>

			<textField>
				<reportElement x="130" y="35" width="300" height="20"/>
				<textFieldExpression><![CDATA[$F{customerName}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="65" width="120" height="20"/>
				<text><![CDATA[Email :]]></text>
			</staticText>

			<textField>
				<reportElement x="130" y="65" width="300" height="20"/>
				<textFieldExpression><![CDATA[$F{customerEmail}]]></textFieldExpression>
			</textField>

		</band>
	</pageHeader>

	<!-- ================= DETAIL ================= -->

	<detail>
		<band height="220">

			<staticText>
				<reportElement x="0" y="0" width="200" height="25"/>
				<textElement>
					<font size="16" isBold="true"/>
				</textElement>
				<text><![CDATA[Booking Details]]></text>
			</staticText>

			<staticText>
				<reportElement x="0" y="40" width="120" height="20"/>
				<text><![CDATA[Status :]]></text>
			</staticText>

			<textField>
				<reportElement x="140" y="40" width="250" height="20"/>
				<textFieldExpression><![CDATA[$F{bookingStatus}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="70" width="120" height="20"/>
				<text><![CDATA[Salon Name :]]></text>
			</staticText>

			<textField>
				<reportElement x="140" y="70" width="300" height="20"/>
				<textFieldExpression><![CDATA[$F{salonName}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="100" width="120" height="20"/>
				<text><![CDATA[Address :]]></text>
			</staticText>

			<textField>
				<reportElement x="140" y="100" width="350" height="20"/>
				<textFieldExpression><![CDATA[$F{salonAddress}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="130" width="120" height="20"/>
				<text><![CDATA[Phone :]]></text>
			</staticText>

			<textField>
				<reportElement x="140" y="130" width="250" height="20"/>
				<textFieldExpression><![CDATA[$F{salonPhone}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="0" y="160" width="120" height="20"/>
				<text><![CDATA[Total Price :]]></text>
			</staticText>

			<textField>
				<reportElement x="140" y="160" width="250" height="20"/>
				<textFieldExpression><![CDATA[
                    "₹ " + $F{totalPrice}
                ]]></textFieldExpression>
			</textField>

		</band>
	</detail>

	<!-- ================= FOOTER ================= -->

	<pageFooter>
		<band height="40">

			<staticText>
				<reportElement x="0" y="10" width="555" height="20"/>
				<textElement textAlignment="Center">
					<font size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[Thank You For Choosing Us!]]></text>
			</staticText>

		</band>
	</pageFooter>

</jasperReport>